meta {
  name: Refresh
  type: http
  seq: 4
}

post {
  url: http://localhost:9001/api/auth/refresh
  body: none
  auth: bearer
}

auth:bearer {
  token: {{refreshToken}}
}

vars:pre-request {
  refreshToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("accessToken", res.body.accessToken);
    bru.setVar("refreshToken", res.body.refreshToken);
  }
}
