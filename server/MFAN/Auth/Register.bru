meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: http://localhost:9001/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "{{email}}",
    "name": "{{name}}",
    "password": "{{password}}"
  }
}

vars:pre-request {
  email: newuser@example.com
  name: New User
  password: password123
}
